# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Prisma database connection string for local SQLite.
DATABASE_URL="file:./dev.db"

# HUGGINGFACE_SPACE_URL: Hugging Face Space Gradio URL (e.g. "username/space-name" or "https://username-space.hf.space")
# Kosongkan jika ingin menggunakan mock inferensi lokal tanpa Hugging Face.
HUGGINGFACE_SPACE_URL="https://your-username-your-space.hf.space"

# VITE_API_URL: URL backend Flask Anda (e.g. "https://api.yourdomain.com")
# Digunakan oleh Vercel Frontend untuk memanggil backend di Shared Hosting Anda.
VITE_API_URL="https://api.yourdomain.com"


